{
  "name": "wdk-checkout",
  "version": "0.1.1",
  "description": "Self-custodial USDT checkout for React Native and React, powered by Tether WDK",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "LICENSE", "README.md"],
  "repository": {
    "type": "git",
    "url": "https://github.com/haryobamy/wdk-checkout.git"
  },
  "homepage": "https://github.com/haryobamy/wdk-checkout#readme",
  "bugs": {
    "url": "https://github.com/haryobamy/wdk-checkout/issues"
  },
  "keywords": ["usdt", "tether", "wdk", "checkout", "crypto", "react-native", "react", "self-custodial", "erc20", "ethereum", "polygon"],
  "scripts": {
    "build": "tsup",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tetherto/wdk": "1.0.0-beta.9",
    "@tetherto/wdk-wallet-evm": "1.0.0-beta.12",
    "@tetherto/wdk-wallet-evm-erc-4337": "1.0.0-beta.6"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.73.0",
    "react-native-keychain": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "react-native": { "optional": true },
    "react-native-keychain": { "optional": true }
  },
  "devDependencies": {
    "@testing-library/react": "^15.0.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^18.3.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "^18.3.0",
    "react-test-renderer": "^18.3.0",
    "ts-jest": "^29.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "license": "MIT"
}
